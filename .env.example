# Environment variables for local development.
# Copy to .env and adjust machine-global values for your system.

# Optional llama.cpp override. Leave unset to use the script default.
# LLAMACPP_REF=0dedb9ef7a71fcebfa6fb17e0d6e6abd6e893376

# Optional shared runtime/device overrides for benchmarks and servers.
# GGML_VK_VISIBLE_DEVICES=0
# AMD_VULKAN_ICD=RADV
# MODEL_DIR=./models
# RESULTS_DIR=./results  # benchmark default and shared fallback

# Server-specific settings live in ignored local per-server configs:
#   config/servers/primary.env
#   config/servers/secondary.env
#
# Start from the tracked examples:
#   config/servers/primary.env.example
#   config/servers/secondary.env.example

# Optional benchmark overrides for scripts/30-bench.sh only.
# GGML_LOG_LEVEL=2
# LLAMA_BENCH_BIN=./third_party/llama.cpp/build-vulkan/bin/llama-bench
# LLAMA_BENCH_NGL=999
# LLAMA_BENCH_THREADS=8
# LLAMA_BENCH_PG=256,128
# LLAMA_BENCH_BATCH=2048
# LLAMA_BENCH_UBATCH=1024
# LLAMA_BENCH_FA=1
