# Environment variables for local development.
# Copy to .env and adjust any values for your machine.

# Optional llama.cpp override. Leave unset to use the script default.
# LLAMACPP_REF=0dedb9ef7a71fcebfa6fb17e0d6e6abd6e893376

# Optional shared runtime overrides for benchmarks and servers.
# GGML_VK_VISIBLE_DEVICES=0
# AMD_VULKAN_ICD=RADV
# MODEL_DIR=./models
# MODEL=./models/Qwen_Qwen3-Coder-Next-Q5_K_M-00001-of-00002.gguf
# RESULTS_DIR=./results

# Optional benchmark overrides for scripts/30-bench.sh only.
# GGML_LOG_LEVEL=2
# LLAMA_BENCH_BIN=./third_party/llama.cpp/build-vulkan/bin/llama-bench
# LLAMA_BENCH_NGL=999
# LLAMA_BENCH_THREADS=8
# LLAMA_BENCH_PG=256,128
# LLAMA_BENCH_BATCH=2048
# LLAMA_BENCH_UBATCH=1024
# LLAMA_BENCH_FA=1

# Optional server overrides for scripts/40-load-model.sh only.
# LLAMA_SERVER_BIN=./third_party/llama.cpp/build-vulkan/bin/llama-server
# LLAMA_SERVER_NGL=999
# LLAMA_SERVER_CTX=130000
# LLAMA_SERVER_THREADS=8
# LLAMA_SERVER_BATCH=2048
# LLAMA_SERVER_UBATCH=2048
# LLAMA_SERVER_HOST=127.0.0.1
# LLAMA_SERVER_PORT=1234
# LLAMA_SERVER_ALIAS=Qwen/Qwen3-Coder-Next-Q5_K_M
# LLAMA_SERVER_FLASH_ATTN=on