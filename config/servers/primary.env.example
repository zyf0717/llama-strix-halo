# First-class primary llama.cpp server profile.
# Copy to config/servers/primary.env and adjust locally.

MODEL=./models/Qwen3.6-35B-A3B-Q6_K_L.gguf
LLAMA_SERVER_ALIAS=Qwen/Qwen3.6-35B-A3B
LLAMA_SERVER_HOST=0.0.0.0
LLAMA_SERVER_PORT=1234
LLAMA_SERVER_RESULTS_DIR=./logs/primary
LLAMA_SERVER_NGL=999
LLAMA_SERVER_CTX=262144
LLAMA_SERVER_THREADS=8
LLAMA_SERVER_BATCH=2048
LLAMA_SERVER_UBATCH=1024
LLAMA_SERVER_PARALLEL=4
LLAMA_SERVER_CACHE_TYPE_K=q8_0
LLAMA_SERVER_CACHE_TYPE_V=q8_0
LLAMA_SERVER_CACHE_REUSE=256
LLAMA_SERVER_FLASH_ATTN=on
LLAMA_SERVER_METRICS=1
LLAMA_SERVER_EXTRA_ARGS=--spec-type draft-mtp --spec-draft-n-max 2 --no-mmproj
