# First-class utility llama.cpp server profile.
# Copy to config/servers/utility.env and adjust locally.

MODEL=./models/utility-model.gguf
LLAMA_SERVER_ALIAS=utility
LLAMA_SERVER_HOST=0.0.0.0
LLAMA_SERVER_PORT=1233
LLAMA_SERVER_RESULTS_DIR=./logs/utility
LLAMA_SERVER_NGL=999
LLAMA_SERVER_CTX=8192
LLAMA_SERVER_THREADS=4
LLAMA_SERVER_BATCH=512
LLAMA_SERVER_UBATCH=512
LLAMA_SERVER_PARALLEL=1
LLAMA_SERVER_CACHE_TYPE_K=q8_0
LLAMA_SERVER_CACHE_TYPE_V=q8_0
LLAMA_SERVER_CACHE_REUSE=
LLAMA_SERVER_FLASH_ATTN=on
LLAMA_SERVER_METRICS=1
LLAMA_SERVER_EXTRA_ARGS=
