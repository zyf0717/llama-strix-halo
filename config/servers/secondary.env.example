# First-class secondary llama.cpp server profile.
# Copy to config/servers/secondary.env and adjust locally.

MODEL=./models/Qwen3-4B-Instruct-2507-UD-Q4_K_XL.gguf
LLAMA_SERVER_ALIAS=Qwen/Qwen3-4B-Instruct-2507
LLAMA_SERVER_HOST=0.0.0.0
LLAMA_SERVER_PORT=1235
LLAMA_SERVER_RESULTS_DIR=./logs/secondary
LLAMA_SERVER_NGL=999
LLAMA_SERVER_CTX=16384
LLAMA_SERVER_THREADS=4
LLAMA_SERVER_BATCH=1024
LLAMA_SERVER_UBATCH=1024
LLAMA_SERVER_PARALLEL=1
LLAMA_SERVER_CACHE_TYPE_K=q8_0
LLAMA_SERVER_CACHE_TYPE_V=q8_0
LLAMA_SERVER_CACHE_REUSE=
LLAMA_SERVER_FLASH_ATTN=on
LLAMA_SERVER_METRICS=1
LLAMA_SERVER_EXTRA_ARGS=
